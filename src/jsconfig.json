{
  "compilerOptions": {
    "jsx": "react-jsx",
    "paths": {
      "app/*": ["./*"],
      "components/*": ["./components/*"],
      "css/*": ["./css/*"]
    },
    "moduleResolution": "bundler",
    "maxNodeModuleJsDepth": 0,
    "checkJs": true,
    "target": "ESNext",
    "module": "ESNext",
    "strictNullChecks": true,
    "resolveJsonModule": true,
    "lib": ["dom", "dom.iterable", "esnext", "WebWorker"]
  },
  "exclude": [
    "node_modules",
    "dist",
    "docs",
    "thinking",
    "OS-DPI",
    "public",
    "components/headmouse/tracky-mouse"
  ]
}
